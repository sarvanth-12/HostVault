SECRET_KEY=change-this-to-a-long-random-secret-key
FLASK_DEBUG=0

# PostgreSQL — use postgres superuser for testing
DATABASE_URL=postgresql://postgres:vijay123@localhost:5432/privcloud_db

# S3 / Backblaze B2 Storage
S3_ENDPOINT=s3.us-east-005.backblazeb2.com
S3_ACCESS_KEY=your_backblaze_keyID
S3_SECRET_KEY=your_backblaze_applicationKey
S3_BUCKET=your-backblaze-bucket
S3_SECURE=True

# Google OAuth
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Add redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
DEFAULT_STORAGE_QUOTA=10737418240
TRASH_RETENTION_DAYS=30
FRONTEND_URL=http://localhost:5000
HOST=0.0.0.0
PORT=5000
